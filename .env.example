# =============================================================================
# Engram — Industrial Knowledge Intelligence (monorepo environment)
# =============================================================================
# Local:      copy to `.env` at repo root → `pnpm dev`
#             optional Mongo: `docker compose -f docker-compose.dev.yml up -d`
# Production: copy to `.env.production` →
#             `docker compose --env-file .env.production up -d --build`
# Vercel:     set NEXT_PUBLIC_* in project settings (frontend only)
#
# Backend: backend/src/loadEnv.ts
# Frontend: NEXT_PUBLIC_* only reaches the browser

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# Local demo without login (never in production)
# NEXT_PUBLIC_ALLOW_PREVIEW_MODE=true

# Google Drive Picker (opens Drive popup to select files)
# Enable Drive API + Picker API; OAuth Web client + API key
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_API_KEY=AIza...

# --- Backend server ---
PORT=3001
FRONTEND_URL=http://localhost:3000

# MongoDB — local compose or Atlas
# Dev compose: mongodb://127.0.0.1:27017/engram
MONGODB_URI=mongodb://127.0.0.1:27017/engram

# JWT auth (RS256) — generate with:
#   pnpm --filter vc-screener-backend run generate:jwt-keys
JWT_ACCESS_TOKEN_SECRET_PRIVATE=
JWT_ACCESS_TOKEN_SECRET_PUBLIC=
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Encrypt per-user API keys at rest (min 32 chars)
USER_API_KEYS_ENCRYPTION_SECRET=

# Local / hackathon demo — unauthenticated preview user (never in production)
# ALLOW_PREVIEW_MODE=true

# Resend — transactional email (optional for demo)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# EMAIL_APP_NAME=Engram
# EMAIL_LOGO_URL=

# Required — console.anthropic.com
ANTHROPIC_API_KEY=
# Model is locked in code (claude-haiku-4-5).

# Behind ALB/nginx (set by docker-compose.yml in production)
# TRUST_PROXY_HOPS=1

# Local document upload dir inside the container (compose sets this)
# ENGRAM_UPLOAD_DIR=./uploads

# Optional web search for OEM / regulatory lookups
TAVILY_API_KEY=

# Rate limits (optional)
# RATE_LIMIT_SCREENER_CHAT_MAX=60
# RATE_LIMIT_ASSISTANT_CHAT_MAX=40

# Cloudflare R2 (optional document storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=engram-docs
R2_PUBLIC_URL=

# Upstash Redis — optional cache (falls back to in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# RAG — optional Atlas vector search for document chunks
OPENAI_API_KEY=
# MONGO_VECTOR_SEARCH_ENABLED=true
